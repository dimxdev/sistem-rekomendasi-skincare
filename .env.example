# Konfigurasi untuk docker-compose. Salin file ini menjadi .env lalu sesuaikan.

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=skincare_db

# Backend
JWT_SECRET=supersecretjwt

# Set true saat pertama kali menjalankan untuk mengisi data awal (admin, dll)
SEED=false

# URL backend yang diakses dari browser (di-bake ke frontend saat build)
VITE_API_URL=http://localhost:3000
